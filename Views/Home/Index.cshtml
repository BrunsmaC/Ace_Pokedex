@{
    ViewData["Title"] = "Home";
}

<div class="p-4 p-md-5 mb-4 rounded-4 bg-light border hero-panel">
    <div class="col-lg-9">
        <h1 class="display-5 fw-bold mb-3">Ace</h1>
        <p class="lead mb-4">
            Ace is a Pokemon social media app where users can browse Pokemon, build teams,
            create posts, and connect through shared Pokemon interests.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg" asp-controller="Pokemon" asp-action="Index">browse pokemon</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Teams" asp-action="Create">create team</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Users" asp-action="Me">open profile</a>
            }
            else
            {
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">create account</a>
                <a class="btn btn-outline-secondary btn-lg" asp-controller="Account" asp-action="Login">sign in</a>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">browse pokemon</h2>
                <p class="mb-0">
                    Search through Pokemon and view details like types, abilities, moves, stats, and other useful battle information.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">build custom teams</h2>
                <p class="mb-0">
                    Create your own Pokemon teams by choosing Pokemon, moves, abilities, items, and natures.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100 shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4">share posts</h2>
                <p class="mb-0">
                    Make posts, share team ideas, and interact with other users through your personal account.
                </p>
            </div>
        </div>
    </div>
</div>