@model TeamAceProject.Models.ViewModels.Teams.TeamDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">@Model.Name</h1>
        <p class="text-muted mb-1">owner: @Model.Username</p>
        <span class="badge @(Model.IsPublic ? "text-bg-success" : "text-bg-secondary")">@(Model.IsPublic ? "public" : "private")</span>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-controller="Posts" asp-action="Create" asp-route-teamId="@Model.Id">create post</a>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-outline-danger">delete team</button>
        </form>
    </div>
</div>

@if (TempData["TeamSuccess"] != null)
{
    <div class="alert alert-success">@TempData["TeamSuccess"]</div>
}
@if (TempData["TeamError"] != null)
{
    <div class="alert alert-danger">@TempData["TeamError"]</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm rounded-4 h-100">
            <div class="card-body">
                <h2 class="h4 mb-3">current members</h2>
                @if (Model.Members.Count == 0)
                {
                    <p class="text-muted mb-0">No pokemon have been added yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var member in Model.Members)
                        {
                            <div class="border rounded-4 p-3">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div class="d-flex gap-3 align-items-center">
                                        @if (!string.IsNullOrWhiteSpace(member.PokemonSpriteUrl))
                                        {
                                            <img src="@member.PokemonSpriteUrl" alt="@member.PokemonName" class="team-sprite" />
                                        }
                                        <div>
                                            <div class="small text-muted">slot @member.SlotIndex</div>
                                            <h3 class="h5 mb-2">@member.PokemonName</h3>
                                            <div><strong>ability:</strong> @(string.IsNullOrWhiteSpace(member.AbilityName) ? "-" : member.AbilityName)</div>
                                            <div><strong>nature:</strong> @(string.IsNullOrWhiteSpace(member.NatureName) ? "-" : member.NatureName)</div>
                                            <div><strong>held item:</strong> @(string.IsNullOrWhiteSpace(member.HeldItemName) ? "-" : member.HeldItemName)</div>
                                            <div><strong>moves:</strong> @(member.Moves.Count == 0 ? "-" : string.Join(", ", member.Moves))</div>
                                        </div>
                                    </div>
                                    <form asp-action="RemoveMember" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="teamId" value="@Model.Id" />
                                        <input type="hidden" name="teamMemberId" value="@member.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">remove</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm rounded-4">
            <div class="card-body">
                <h2 class="h4 mb-3">add pokemon</h2>
                <form asp-action="AddMember" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TeamId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">pokemon</label>
                        <select name="PokemonName" id="pokemon-select" class="form-select">
                            <option value="">loading pokemon...</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ability</label>
                        <select name="AbilityName" id="ability-select" class="form-select">
                            <option value="">-- select a pokemon first --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">nature</label>
                        <select name="NatureName" class="form-select">
                            <option value="">-- none --</option>
                            <option>Hardy</option><option>Lonely</option><option>Brave</option>
                            <option>Adamant</option><option>Naughty</option><option>Bold</option>
                            <option>Docile</option><option>Relaxed</option><option>Impish</option>
                            <option>Lax</option><option>Timid</option><option>Hasty</option>
                            <option>Serious</option><option>Jolly</option><option>Naive</option>
                            <option>Modest</option><option>Mild</option><option>Quiet</option>
                            <option>Bashful</option><option>Rash</option><option>Calm</option>
                            <option>Gentle</option><option>Sassy</option><option>Careful</option>
                            <option>Quirky</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">held item</label>
                        <select name="HeldItemName" id="held-item-select" class="form-select">
                            <option value="">-- none --</option>
                        </select>
                    </div>

                    <div class="mb-2"><strong>moves</strong></div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <select name="Move1" id="move-1" class="form-select">
                                <option value="">-- select a pokemon first --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select name="Move2" id="move-2" class="form-select">
                                <option value="">-- select a pokemon first --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select name="Move3" id="move-3" class="form-select">
                                <option value="">-- select a pokemon first --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <select name="Move4" id="move-4" class="form-select">
                                <option value="">-- select a pokemon first --</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">add to team</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(async function () {
    const pokemonSelect  = document.getElementById('pokemon-select');
    const abilitySelect  = document.getElementById('ability-select');
    const heldItemSelect = document.getElementById('held-item-select');
    const moveSelects    = [1, 2, 3, 4].map(n => document.getElementById(`move-${n}`));

    function toDisplay(apiName) {
        return apiName.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    function populateSelect(select, names, placeholder) {
        select.innerHTML = '';
        const blank = document.createElement('option');
        blank.value = '';
        blank.textContent = placeholder;
        select.appendChild(blank);
        names.forEach(name => {
            const opt = document.createElement('option');
            opt.value = name;
            opt.textContent = name;
            select.appendChild(opt);
        });
    }

    // Fetch pokemon list and items list in parallel
    const [pokemonRes, itemsRes] = await Promise.allSettled([
        fetch('https://pokeapi.co/api/v2/pokemon?limit=1302'),
        fetch('https://pokeapi.co/api/v2/item?limit=2500')
    ]);

    if (pokemonRes.status === 'fulfilled' && pokemonRes.value.ok) {
        const data = await pokemonRes.value.json();
        populateSelect(pokemonSelect, data.results.map(p => toDisplay(p.name)), '-- select pokemon --');
    } else {
        pokemonSelect.innerHTML = '<option value="">could not load pokemon</option>';
    }

    if (itemsRes.status === 'fulfilled' && itemsRes.value.ok) {
        const data = await itemsRes.value.json();
        data.results.forEach(i => {
            const opt = document.createElement('option');
            opt.value = toDisplay(i.name);
            opt.textContent = toDisplay(i.name);
            heldItemSelect.appendChild(opt);
        });
    }

    // When a pokemon is selected, fetch its abilities + moves
    pokemonSelect.addEventListener('change', async function () {
        const normalized = this.value.trim().toLowerCase().replace(/\s+/g, '-');
        if (!normalized) {
            abilitySelect.innerHTML = '<option value="">-- select a pokemon first --</option>';
            moveSelects.forEach(s => { s.innerHTML = '<option value="">-- select a pokemon first --</option>'; });
            return;
        }
        try {
            const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${normalized}`);
            if (!res.ok) return;
            const pokemon = await res.json();

            abilitySelect.innerHTML = '<option value="">-- select ability --</option>';
            pokemon.abilities.forEach(a => {
                const opt = document.createElement('option');
                opt.value = toDisplay(a.ability.name);
                opt.textContent = toDisplay(a.ability.name);
                abilitySelect.appendChild(opt);
            });

            const moveOptions = pokemon.moves.map(m => {
                const opt = document.createElement('option');
                opt.value = toDisplay(m.move.name);
                opt.textContent = toDisplay(m.move.name);
                return opt;
            });
            moveSelects.forEach(select => {
                select.innerHTML = '<option value="">-- none --</option>';
                moveOptions.forEach(opt => select.appendChild(opt.cloneNode(true)));
            });
        } catch {
            // silently ignore network errors
        }
    });
})();
</script>
}
